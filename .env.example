WANWEI_BIND_HOST=127.0.0.1
WANWEI_PORT=8010
# 真实 MCP stdio 默认禁用。启用时须同时开启 device 档，并以逗号分隔列出
# 受信任的 MCP 启动器文件名或绝对路径（不要允许 python/powershell/cmd 等通用解释器）。
WANWEI_DEVICE_GEAR_ENABLED=0
WANWEI_MCP_STDIO_COMMANDS=
# compose-only：仅供 compose.yaml 的 docker secret 引用（指向宿主机上的 API key 文件）。
# 后端进程本身不读取本变量；直接运行后端请改用 WANWEI_API_KEY 或 WANWEI_API_KEY_FILE。
WANWEI_API_KEY_SOURCE=./secrets/wanwei_api_key.txt
# Fernet key: 32 random bytes encoded as padded base64url. Set it in deployments;
# an unset value derives from WANWEI_API_KEY only for development compatibility.
WANWEI_ENCRYPTION_KEY=
